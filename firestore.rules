// ============================================================
// FIRESTORE RULES — Be8 Portal de Cotações
// Copie e cole no Firebase Console → Firestore → Rules
// Desenvolvido por Lucas L. Diogo para Be8 2026
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Admin: qualquer usuário autenticado com e-mail (não anônimo)
      return request.auth != null && request.auth.token.email != null;
    }

    function isAnonymous() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isOwner(email) {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email == email;
    }

    // ─── REQUESTERS ──────────────────────────────────────────
    // Qualquer usuário logado (anon ou real) pode criar/ler seu próprio requester
    match /requesters/{requesterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── SOLICITACOES ─────────────────────────────────────────
    match /solicitacoes/{solId} {
      // Leitura: anônimo lê apenas as próprias; admin lê todas
      allow read: if isSignedIn() && (
        isAdmin()
        || (isAnonymous() && resource.data.requesterEmail == null)
        || (!isAnonymous() && resource.data.requesterEmail == request.auth.token.email)
      );

      // Qualquer usuário logado pode criar solicitação
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['requesterEmail','cidadeColeta','cidadeDestino'])
        && request.resource.data.requesterEmail is string
        && request.resource.data.requesterEmail.size() > 0;

      // Update: owner edita os próprios campos não-finalizados; admin edita tudo
      allow update: if isSignedIn() && (
        isAdmin()
        || (
          resource.data.requesterEmail == request.auth.token.email
          && !(resource.data.status in ['Entregue', 'Cancelado'])
        )
      );

      // Apenas admin pode excluir
      allow delete: if isAdmin();
    }

    // ─── CONFIGURACOES ────────────────────────────────────────
    match /configuracoes/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── UNIDADES (coleção alternativa se quiser persistir no Firestore) ──
    match /unidades/{unidadeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

  }
}

// ============================================================
// STORAGE RULES — Be8 Portal de Cotações
// Copie e cole no Firebase Console → Storage → Rules
// ============================================================

