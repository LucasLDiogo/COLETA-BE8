{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "README.md",
      "node_modules"
    ],
    "rewrites": [],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
